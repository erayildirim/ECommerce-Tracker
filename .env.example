# ========================================
# DATABASE CONFIGURATION
# ========================================
# Local dev: DB_HOST=localhost, DB_PORT=5433
# Inside Docker: DB_HOST=postgres, DB_PORT=5432
DB_HOST=localhost
DB_PORT=5433
DB_USER=ecommerce_user
DB_PASSWORD=change_me
DB_NAME=ecommerce_tracker

# ========================================
# API CONFIGURATION
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# ========================================
# SCRAPING CONFIGURATION
# ========================================
# Set PLAYWRIGHT_HEADLESS=False to watch the browser window during scraping
PLAYWRIGHT_HEADLESS=True
MAX_CONCURRENT_SCRAPERS=5
SCRAPER_TIMEOUT=60000
RETRY_ATTEMPTS=3

# ========================================
# LOGGING CONFIGURATION
# ========================================
# Set LOG_LEVEL=DEBUG to see selector-level debug output from scrapers
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
